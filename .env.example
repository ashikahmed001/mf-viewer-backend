# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local SQLite path (used when LOCAL=true)
DB_PATH=./data/mf_portfolio.db

# Turso (production cloud SQLite)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ─── Clerk (Auth) ─────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=you@example.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins. Leave blank locally (allows all).
# Example for production: https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=

# ─── Razorpay (Payments) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_PLAN_MONTHLY=plan_...
RAZORPAY_PLAN_ANNUAL=plan_...
